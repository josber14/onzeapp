model P2PChatState {
  id                Int       @id @default(autoincrement())
  tenantId          Int
  exchange          String
  orderNumber       String
  state             String    @default("new")
  counterparty      String?
  isCompany         Boolean   @default(false)
  isReturning       Boolean   @default(false)
  previousBank      String?
  chosenBank        String?
  chosenAccountIds  Json?
  // IDs de cuenta en el MISMO orden exacto mostrado en el último menú
  // "1) Banco X 2) Banco Y..." — se usa para interpretar un "1"/"2"/"3"
  // numérico. Nunca se re-deriva el orden fresco de la base de datos al
  // interpretar la respuesta: si el orden de las cuentas cambia (ej. un
  // reordenamiento manual) entre que se muestra el menú y que el comprador
  // responde, un número ya no correspondería al banco que realmente vio.
  pendingBankMenuIds Json?
  // El estado en el que estaba la conversación justo antes del aviso de
  // "orden por vencer" (awaiting_problem) — se usa para volver ahí una vez
  // resuelto ese aviso puntual, en vez de forzar siempre a "account_sent"
  // sin importar en qué parte de la conversación se haya interrumpido.
  preInterruptState  String?
  erutRequested     Boolean   @default(false)
  erutReceived      Boolean   @default(false)
  retryCount        Int       @default(0)
  transferFailCount Int       @default(0)
  partialAmount     Decimal?  @db.Decimal(18, 8)
  totalAmount       Decimal?  @db.Decimal(18, 8)
  realName          String?
  pendingFirstMsg   String?
  lastClientMsgAt   DateTime?
  lastBotMsgAt      DateTime?
  lastBotMsg        String?
  lastClientMsgSeen String?
  appealAt          DateTime?
  paidAt            DateTime?
  completedAt       DateTime?
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  Tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, exchange, orderNumber])
  @@index([tenantId, exchange, state])
}

// El apodo de Binance que se ve ANTES del pago (order.counterPartNickName)
// viene enmascarado a 3 letras + asteriscos y colisiona entre compradores
// distintos (confirmado en vivo jul 2026, ver comentario de getBuyerHistory
// en chat-agent.ts) — no sirve para reconocer "es la misma persona de antes".
// El evento de chat "seller_payed" (dispara cuando el comprador marca
// "Pagado") sí trae el apodo REAL sin enmascarar y el nombre legal completo.
// Esta tabla guarda esa asociación la primera vez que se ve, para poder
// reconocer a un comprador recurrente en un pedido FUTURO — nunca en el
// saludo inicial del MISMO pedido, porque ese evento todavía no ocurrió.
model P2PBuyerIdentity {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  exchange   String
  label      String   @default("ONZE")
  nickName   String
  realName   String
  orderCount Int      @default(1)
  lastBank      String?
  lastAccountId Int?
  lastIsCompany Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
  Tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, exchange, label, nickName])
}

// Bloqueo real (no en memoria) contra procesamiento concurrente del chat.
// Necesario porque Vercel puede levantar varias instancias del mismo
// servidor en paralelo para atender /api/p2p/bot/cycle (llamado cada
// ~300ms) — un bloqueo en memoria de una instancia no lo ve otra instancia
// distinta. `id` = `${tenantId}:${label}:${exchange}`. Confirmado en vivo
// jul 2026: incluso con el bloqueo en memoria, el mismo mensaje del
// comprador seguía generando respuestas contradictorias.
model ChatProcessingLock {
  id       String   @id
  lockedAt DateTime @default(now())
}

