  exchange    String
  label       String
  accountType String
  accountInfo Json
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  Tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model P2PBotExchangeConfig {
  id                   Int       @id @default(autoincrement())
  tenantId             Int
  exchange             String
  enabled              Boolean   @default(false)
  strategy             String    @default("top1")
  top1Diff             Decimal   @default(0.1) @db.Decimal(18, 8)
  spreadPct            Decimal   @default(0.5) @db.Decimal(8, 4)
  priceFloorPct        Decimal   @default(0.2) @db.Decimal(8, 4)
  priceSource          String    @default("manual")
  dailyVolumeCapUsdt   Decimal?  @db.Decimal(18, 8)
  circuitBreakPct      Decimal   @default(3) @db.Decimal(8, 4)
  pauseUntil           DateTime?
  lastStartedAt        DateTime?
  lastStoppedAt        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @default(now())
  cycleInterval        Int       @default(10)
  minCompetitorCapital Decimal?  @db.Decimal(18, 2)
  adUpdateCount        Int       @default(0)
  competePayTypes      Json?
  chatBotEnabled       Boolean   @default(false)
  chatCookies          Json?
  commissionPct        Decimal   @default(0.14) @db.Decimal(8, 4)
  safeMarginPct        Decimal   @default(0) @db.Decimal(8, 4)
  Tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, exchange])
  @@index([tenantId])
}

model P2PBotAd {
  id                     Int       @id @default(autoincrement())
  tenantId               Int
  exchange               String
  adId                   String?
  tradeType              String    @default("SELL")
  asset                  String    @default("USDT")
  fiat                   String    @default("CLP")
  priceType              String    @default("fixed")
  price                  Decimal   @db.Decimal(18, 8)
  amount                 Decimal   @db.Decimal(18, 8)
  amountType             String    @default("fixed")
  minAmount              Decimal   @db.Decimal(18, 8)
  maxAmount              Decimal   @db.Decimal(18, 8)
  paymentMethods         Json      @default("[]")
  payTime                Int       @default(15)
  status                 String    @default("online")
  isActive               Boolean   @default(true)
  botManaged             Boolean   @default(false)
  botEnabled             Boolean   @default(false)
  botStrategy            String?   @default("top1")
  botTop1Diff            Decimal?  @db.Decimal(18, 8)
  botSpreadPct           Decimal?  @db.Decimal(8, 4)
  botPriceFloorPct       Decimal?  @db.Decimal(8, 4)
  botPriceSource         String?   @default("manual")
  botCommissionPct       Decimal?  @db.Decimal(8, 4)
  botSafeMarginPct       Decimal?  @db.Decimal(8, 4)
  botMinCompetitorCapital Decimal? @db.Decimal(18, 2)
  botCompetePayTypes     Json?
  botCycleInterval       Int?
  botCircuitBreakPct     Decimal? @db.Decimal(8, 4)
  botDailyVolumeCapUsdt  Decimal? @db.Decimal(18, 8)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @default(now())
  Tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([exchange])
}

model P2PBotMarketSnapshot {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  exchange    String
  side        String   @default("1")
  cycleAt     DateTime @default(now())
  competitors Json     @default("[]")
  ourAd       Json?
  targetPrice Decimal? @db.Decimal(18, 4)
  createdAt   DateTime @default(now())

  Tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, exchange, cycleAt])
  @@index([tenantId, cycleAt])
}

