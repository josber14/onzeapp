// Pago manual aparte de las ventas sincronizadas de Binance — ej: el socio
// pagó directo al proveedor con plata propia (no proveniente de una venta).
// Se guarda como registro propio (no se resta directo de capacityClp) para
// mantener trazabilidad de cada ajuste, y porque NUNCA debe afectar el
// cálculo de costo/ganancia (que sale solo de PartnerSale vía FIFO en
// computeFifo) — solo reduce el saldo pendiente que se le muestra al socio.
model PartnerCapacityPayment {
  id         Int             @id @default(autoincrement())
