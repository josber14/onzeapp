  isActive     Boolean   @default(true)
  lastTestedAt DateTime?
  testStatus   String?
  // Contraseña de fondos de Binance (Fund Password) — DISTINTA de apiKey/secretKey
  // y de la clave de login. Binance la exige (cifrada con su llave RSA pública,
  // ver lib/p2p-bot/binance-adapter.ts releaseAssets) en cada liberación de
  // orden C2C. Cifrada acá con AES-256-GCM (reversible, no hash) porque hace
  // falta el valor real para cifrarla de nuevo con la llave RSA de Binance en
  // cada llamada — nunca se expone en ninguna respuesta de API.
  fundPasswordEnc String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
