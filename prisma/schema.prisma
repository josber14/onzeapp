generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Plan {
  id                         Int            @id @default(autoincrement())
  code                       String         @unique
  name                       String
  description                String?
  priceMonthly               Decimal?       @db.Decimal(12, 2)
  currencyCode               String         @default("USD")
  maxOperators               Int?
  allowBasePropia            Boolean        @default(false)
  allowInternalOperatorAdmin Boolean        @default(false)
  allowKycModule             Boolean        @default(false)
  allowUsdtAnalysis          Boolean        @default(false)
  allowPairAdmin             Boolean        @default(false)
  active                     Boolean        @default(true)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  subscriptions              Subscription[]
  tenants                    Tenant[]
}

model Tenant {
  id                    Int                    @id @default(autoincrement())
  code                  String                 @unique
  legalName             String?
  tradeName             String
  ownerUserId           Int?
  dataSourceMode        DataSourceMode
  planId                Int?
  isOnzeInternal        Boolean                @default(false)
  active                Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  auditLogs             AuditLog[]
  balanceMovements      BalanceMovement[]
  binanceCredentials    BinanceCredentials[]
  binanceOrders         BinanceOrder[]
  bybitCredentials      BybitCredentials[]
  collaboratorPayments  CollaboratorPayment[]
  dataSources           DataSource[]
  earningsMovements     EarningsMovement[]
  expenses              Expense[]
  initialCapitals       InitialCapital[]
  internalFundings      InternalFunding[]
  liquidityAlerts       LiquidityAlert[]
  OkxCredentials        OkxCredentials[]
  operations            Operation[]
  customers             OperatorCustomer[]
  P2PAccount            P2PAccount[]
  p2pBotConfig          P2PBotConfig?
  P2PBotExchangeConfig  P2PBotExchangeConfig[]
  p2pBotLogs            P2PBotLog[]
  p2pBotOrders          P2PBotOrder[]
  p2pBotAds             P2PBotAd[]
  p2pChatStates         P2PChatState[]
  p2pBuyerIdentities    P2PBuyerIdentity[]
  p2pBotMarketSnapshots P2PBotMarketSnapshot[]
  p2pCapacities         P2PCapacity[]
  p2pCycles             P2PCycle[]
  p2pWebAuthnCredentials P2PWebAuthnCredential[]
  p2pWebAuthnChallenges P2PWebAuthnChallenge[]
  p2pReleaseAuthTokens  P2PReleaseAuthToken[]
  usdtClients           UsdtClient[]
  usdtMarginTiers       UsdtMarginTier[]
  partnerAccounts       PartnerAccount[]
  partnerCapacities     PartnerCapacity[]
  partnerSales          PartnerSale[]
  rateLists             RateList[]
  subscriptions         Subscription[]
  ownerUser             User?                  @relation("TenantOwner", fields: [ownerUserId], references: [id])
  plan                  Plan?                  @relation(fields: [planId], references: [id])
  balances              TenantCountryBalance[]
  pairs                 TenantPair[]
  settings              TenantSettings?
  users                 User[]
}

model Subscription {
  id                     Int       @id @default(autoincrement())
  tenantId               Int
  planId                 Int
  status                 String
  startedAt              DateTime?
  endsAt                 DateTime?
  externalProvider       String?
  externalSubscriptionId String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  plan                   Plan      @relation(fields: [planId], references: [id])
  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id                   Int                   @id @default(autoincrement())
  tenantId             Int?
  role                 AccountRole
  status               AccountStatus         @default(pendiente)
  email                String                @unique
  passwordHash         String
  fullName             String
  phone                String?
  residenceCountryCode String?
  operatorMode         OperatorMode?
  dataSourceMode       DataSourceMode?
  percentageRate       Decimal?              @db.Decimal(8, 4)
  partnerSharePercent  Decimal?              @db.Decimal(8, 4)
  canManageOperators   Boolean               @default(false)
  canConnectOwnSheet   Boolean               @default(false)
  canEditBranding      Boolean               @default(false)
  notes                String?
  approvedByUserId     Int?
  approvedAt           DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  auditLogs            AuditLog[]
  collaboratorPayments CollaboratorPayment[]
  earningsMovements    EarningsMovement[]
  expenses             Expense[]
  createdOperations    Operation[]
  ownedCustomers       OperatorCustomer[]
  rateLists            RateList[]
  ownedTenant          Tenant[]              @relation("TenantOwner")
  approvedBy           User?                 @relation("UserApprovals", fields: [approvedByUserId], references: [id])
  approvedUsers        User[]                @relation("UserApprovals")
  tenant               Tenant?               @relation(fields: [tenantId], references: [id])
  reviewedKycs         UserKyc[]             @relation("KycReviewer")
  kyc                  UserKyc?

  @@index([tenantId])
  @@index([status])
}

model UserKyc {
  id                    Int       @id @default(autoincrement())
  userId                Int       @unique
  status                KycStatus @default(no_requerido)
  documentType          String?
  documentNumber        String?
  documentFrontUrl      String?
  documentBackUrl       String?
  selfieUrl             String?
  addressProofUrl       String?
  declarationAccepted   Boolean   @default(false)
  declarationAcceptedAt DateTime?
  reviewedByUserId      Int?
  reviewedAt            DateTime?
  reviewNotes           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  reviewedBy            User?     @relation("KycReviewer", fields: [reviewedByUserId], references: [id])
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DataSource {
  id                Int            @id @default(autoincrement())
  tenantId          Int
  mode              DataSourceMode
  provider          String
  sourceName        String
  sheetUrl          String?
  csvUrl            String?
  isPrimary         Boolean        @default(true)
  syncEnabled       Boolean        @default(true)
  lastSyncedAt      DateTime?
  validationStatus  String?
  validationMessage String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Country {
  id                       Int                    @id @default(autoincrement())
  code                     String                 @unique
  name                     String
  currencyCode             String
  flagEmoji                String?
  active                   Boolean                @default(true)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  balanceMovements         BalanceMovement[]
  expenses                 Expense[]
  initialCapitals          InitialCapital[]
  fundingSourceLinks       InternalFunding[]      @relation("FundingSourceCountry")
  fundingTargetLinks       InternalFunding[]      @relation("FundingTargetCountry")
  liquidityAlerts          LiquidityAlert[]
  convertedProfitOps       Operation[]            @relation("OperationConvertedProfitTargetCountry")
  destinationOps           Operation[]            @relation("OperationDestinationCountry")
  originOperations         Operation[]            @relation("OperationOriginCountry")
  profitBaseOps            Operation[]            @relation("OperationProfitBaseCountry")
  shortageOps              Operation[]            @relation("OperationShortageCountry")
  rateListPairsDestination RateListPair[]         @relation("RateListPairDestination")
  rateListPairsOrigin      RateListPair[]         @relation("RateListPairOrigin")
  balances                 TenantCountryBalance[]
  destinationPairs         TenantPair[]           @relation("DestinationCountry")
  originPairs              TenantPair[]           @relation("OriginCountry")
}

model TenantPair {
  id                   Int              @id @default(autoincrement())
  tenantId             Int
  originCountryId      Int
  destinationCountryId Int
  pairCode             String
  active               Boolean          @default(true)
  decimals             Int?
  notes                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  destinationCountry   Country          @relation("DestinationCountry", fields: [destinationCountryId], references: [id])
  originCountry        Country          @relation("OriginCountry", fields: [originCountryId], references: [id])
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rates                TenantPairRate[]

  @@unique([tenantId, originCountryId, destinationCountryId])
  @@index([tenantId])
}

model TenantPairRate {
  id                   Int        @id @default(autoincrement())
  tenantPairId         Int
  buyOriginValue       Decimal?   @db.Decimal(18, 8)
  sellDestinationValue Decimal?   @db.Decimal(18, 8)
  costRate             Decimal?   @db.Decimal(18, 8)
  providerRate         Decimal?   @db.Decimal(18, 8)
  retailRate           Decimal?   @db.Decimal(18, 8)
  active               Boolean    @default(true)
  sourceRowRef         String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  tenantPair           TenantPair @relation(fields: [tenantPairId], references: [id], onDelete: Cascade)

  @@index([tenantPairId])
}

model OperatorCustomer {
  id          Int         @id @default(autoincrement())
  tenantId    Int
  ownerUserId Int
  fullName    String
  phone       String?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  operations  Operation[]
  ownerUser   User        @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Operation {
  id                                Int                 @id @default(autoincrement())
  tenantId                          Int
  createdByUserId                   Int
  operationNumber                   String
  operationDate                     DateTime
  operationTime                     DateTime            @default(now())
  operationType                     String?
  note                              String?
  customerId                        Int?
  customerNameSnapshot              String?
  operatorMode                      OperatorMode
  percentageRateSnapshot            Decimal?            @db.Decimal(8, 4)
  partnerSharePercentSnapshot       Decimal?            @db.Decimal(8, 4)
  originCountryId                   Int
  destinationCountryId              Int
  originCurrencyCode                String
  destinationCurrencyCode           String
  amountOrigin                      Decimal             @db.Decimal(18, 8)
  amountDestination                 Decimal?            @db.Decimal(18, 8)
  buyOriginValueSnapshot            Decimal?            @db.Decimal(18, 8)
  sellDestinationValueSnapshot      Decimal?            @db.Decimal(18, 8)
  costRateSnapshot                  Decimal?            @db.Decimal(18, 8)
  providerRateSnapshot              Decimal?            @db.Decimal(18, 8)
  retailRateSnapshot                Decimal?            @db.Decimal(18, 8)
  userOperatingRateSnapshot         Decimal?            @db.Decimal(18, 8)
  profitBaseCountryId               Int?
  profitBaseCurrencyCode            String?
  profitTotalAmount                 Decimal             @default(0) @db.Decimal(18, 8)
  operatorProfitAmount              Decimal             @default(0) @db.Decimal(18, 8)
  superAdminProfitAmount            Decimal             @default(0) @db.Decimal(18, 8)
  convertedProfit                   Boolean             @default(false)
  convertedProfitTargetCountryId    Int?
  convertedProfitTargetCurrencyCode String?
  convertedProfitAmount             Decimal?            @db.Decimal(18, 8)
  conversionProviderRateSnapshot    Decimal?            @db.Decimal(18, 8)
  payoutCurrencyMode                PayoutCurrencyMode?
  payoutAmountToOperator            Decimal?            @db.Decimal(18, 8)
  payoutCurrencyCode                String?
  payoutUsdtAmount                  Decimal?            @db.Decimal(18, 8)
  createdAt                         DateTime            @default(now())
  updatedAt                         DateTime            @updatedAt
  liquidityShortage                 Decimal?            @db.Decimal(18, 8)
  liquidityStatus                   LiquidityStatus     @default(ok)
  needsFunding                      Boolean             @default(false)
  shortageCountryId                 Int?
  shortageCurrencyCode              String?
  deleted                           Boolean             @default(false)
  deletedAt                         DateTime?
  status                            String?
  onzeProfitOriginAmount            Decimal?            @db.Decimal(18, 8)
  onzeProfitOriginCurrencyCode      String?
  onzeProfitUsdt                    Decimal?            @db.Decimal(18, 8)
  operatorPayoutStatus              String?             @default("pending")
  operatorProfitConverted           Boolean             @default(false)
  operatorProfitFinalAmount         Decimal?            @db.Decimal(18, 8)
  operatorProfitFinalCurrencyCode   String?
  operatorProfitPaidAmount          Decimal?            @db.Decimal(18, 8)
  operatorProfitPendingAmount       Decimal?            @db.Decimal(18, 8)
  balanceMovements                  BalanceMovement[]
  earningsMovements                 EarningsMovement[]
  internalFundings                  InternalFunding[]
  liquidityAlerts                   LiquidityAlert[]
  convertedProfitTargetCountry      Country?            @relation("OperationConvertedProfitTargetCountry", fields: [convertedProfitTargetCountryId], references: [id])
  createdByUser                     User                @relation(fields: [createdByUserId], references: [id])
  customer                          OperatorCustomer?   @relation(fields: [customerId], references: [id])
  destinationCountry                Country             @relation("OperationDestinationCountry", fields: [destinationCountryId], references: [id])
  originCountry                     Country             @relation("OperationOriginCountry", fields: [originCountryId], references: [id])
  profitBaseCountry                 Country?            @relation("OperationProfitBaseCountry", fields: [profitBaseCountryId], references: [id])
  shortageCountry                   Country?            @relation("OperationShortageCountry", fields: [shortageCountryId], references: [id])
  tenant                            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, operationNumber])
  @@index([tenantId, operationDate])
  @@index([createdByUserId])
  @@index([operatorMode])
}

model TenantCountryBalance {
  id                     Int      @id @default(autoincrement())
  tenantId               Int
  countryId              Int
  balanceLocal           Decimal  @default(0) @db.Decimal(18, 8)
  buyOriginValueSnapshot Decimal? @db.Decimal(18, 8)
  balanceUsdt            Decimal? @db.Decimal(18, 8)
  sourceRef              String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  country                Country  @relation(fields: [countryId], references: [id])
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, countryId])
  @@index([tenantId])
}

model InitialCapital {
  id           Int      @id @default(autoincrement())
  tenantId     Int
  countryId    Int
  currencyCode String
  amount       Decimal  @db.Decimal(18, 8)
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  country      Country  @relation(fields: [countryId], references: [id])
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, countryId, currencyCode])
  @@index([tenantId])
}

model BalanceMovement {
  id           Int                      @id @default(autoincrement())
  tenantId     Int
  operationId  Int?
  fundingId    Int?
  countryId    Int
  currencyCode String
  direction    BalanceMovementDirection
  movementType BalanceMovementType
  amount       Decimal                  @db.Decimal(18, 8)
  note         String?
  createdAt    DateTime                 @default(now())
  country      Country                  @relation(fields: [countryId], references: [id])
  funding      InternalFunding?         @relation(fields: [fundingId], references: [id])
  operation    Operation?               @relation(fields: [operationId], references: [id])
  tenant       Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([operationId])
  @@index([fundingId])
  @@index([countryId])
}

model LiquidityAlert {
  id               Int                  @id @default(autoincrement())
  tenantId         Int
  operationId      Int
  countryId        Int
  currencyCode     String
  availableAmount  Decimal              @db.Decimal(18, 8)
  requiredAmount   Decimal              @db.Decimal(18, 8)
  shortageAmount   Decimal              @db.Decimal(18, 8)
  status           LiquidityAlertStatus @default(abierta)
  note             String?
  createdAt        DateTime             @default(now())
  resolvedAt       DateTime?
  internalFundings InternalFunding[]
  country          Country              @relation(fields: [countryId], references: [id])
  operation        Operation            @relation(fields: [operationId], references: [id], onDelete: Cascade)
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([operationId])
  @@index([countryId])
  @@index([status])
}

model InternalFunding {
  id                 Int               @id @default(autoincrement())
  tenantId           Int
  operationId        Int?
  liquidityAlertId   Int?
  sourceCountryId    Int
  sourceCurrencyCode String
  sourceAmount       Decimal           @db.Decimal(18, 8)
  targetCountryId    Int
  targetCurrencyCode String
  targetAmount       Decimal           @db.Decimal(18, 8)
  referenceRate      Decimal?          @db.Decimal(18, 8)
  executedRate       Decimal           @db.Decimal(18, 8)
  costUsdt           Decimal?          @db.Decimal(18, 8)
  note               String?
  status             String            @default("completed")
  createdAt          DateTime          @default(now())
  balanceMovements   BalanceMovement[]
  liquidityAlert     LiquidityAlert?   @relation(fields: [liquidityAlertId], references: [id])
  operation          Operation?        @relation(fields: [operationId], references: [id])
  sourceCountry      Country           @relation("FundingSourceCountry", fields: [sourceCountryId], references: [id])
  targetCountry      Country           @relation("FundingTargetCountry", fields: [targetCountryId], references: [id])
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([operationId])
  @@index([liquidityAlertId])
  @@index([sourceCountryId])
  @@index([targetCountryId])
}

model EarningsMovement {
  id           Int                  @id @default(autoincrement())
  tenantId     Int
  userId       Int
  operationId  Int?
  movementType EarningsMovementType
  amount       Decimal              @db.Decimal(18, 8)
  currencyCode String
  note         String?
  createdAt    DateTime             @default(now())
  operation    Operation?           @relation(fields: [operationId], references: [id])
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([operationId])
}

model CollaboratorPayment {
  id           Int      @id @default(autoincrement())
  tenantId     Int
  userId       Int
  currencyCode String
  amount       Decimal  @db.Decimal(18, 8)
  paymentDate  DateTime
  note         String?
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
}

model Expense {
  id              Int      @id @default(autoincrement())
  tenantId        Int
  expenseDate     DateTime
  category        String
  countryId       Int
  currencyCode    String
  amount          Decimal  @db.Decimal(18, 8)
  note            String?
  createdByUserId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  country         Country  @relation(fields: [countryId], references: [id])
  createdByUser   User?    @relation(fields: [createdByUserId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([countryId])
  @@index([expenseDate])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actorUserId Int?
  tenantId    Int?
  action      String
  entityType  String
  entityId    String?
  payload     Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation(fields: [actorUserId], references: [id])
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
}

model TenantSettings {
  id                              Int      @id @default(autoincrement())
  tenantId                        Int      @unique
  inviteCode                      String?
  whatsappClosingNumber           String?
  sheetUrl                        String?
  allowInternalOperatorManagement Boolean  @default(false)
  allowPairCreation               Boolean  @default(false)
  allowCountryCreation            Boolean  @default(false)
  allowSheetSync                  Boolean  @default(true)
  allowUsdtAnalysis               Boolean  @default(false)
  allowKyc                        Boolean  @default(false)
  themeOverrides                  Json?
  p2pResetCutoff                  BigInt?
  // Clave de 4 dígitos para proteger "Liberar" en el panel P2P (jul 2026) —
  // nunca se guarda en texto plano, solo el hash (bcryptjs, mismo patrón que
  // el login). El bloqueo temporal es para que no se pueda "adivinar" por
  // fuerza bruta (4 dígitos = solo 10.000 combinaciones posibles).
  releasePinHash                  String?
  releasePinFailedAttempts        Int       @default(0)
  releasePinLockedUntil           DateTime?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
  tenant                          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Huella/Face ID registrada para proteger "Liberar" en el panel P2P — el
// estándar WebAuthn nunca nos da acceso a la huella en sí, solo una llave
// pública que sirve para VERIFICAR firmas hechas con el sensor del propio
// dispositivo del usuario.
model P2PWebAuthnCredential {
  id           Int      @id @default(autoincrement())
  tenantId     Int
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt   @default(0)
  transports   Json?
  deviceLabel  String?
  createdAt    DateTime @default(now())
  Tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Challenge temporal de una ceremonia WebAuthn en curso (registro o
// autenticación) — se genera, se guarda acá, y se borra/expira apenas se
// usa. Nunca vive más que unos minutos.
model P2PWebAuthnChallenge {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  challenge   String
  purpose     String
  // Solo se usa cuando purpose="authenticate" para liberar una orden — así
  // auth-verify sabe a qué orden atar el token que emite al validar la huella.
  orderNumber String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  Tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Token corto (~2 min) que autoriza UNA liberación puntual de UNA orden
// específica — se emite recién después de validar el PIN o la huella
// correctamente, y se consume (marca used=true) al usarlo. Nunca se puede
// reutilizar para otra orden ni más de una vez.
model P2PReleaseAuthToken {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  token       String   @unique
  orderNumber String
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  Tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderNumber])
}

// ─── Clientes de venta de USDT al mayor (producto nuevo, 100% aislado del
// panel ONZE — login/sesión propios, ver lib/usdt-client-session.ts) ───

model UsdtClient {
  id               Int       @id @default(autoincrement())
  tenantId         Int
  email            String
  passwordHash     String
  fullName         String
  // pending_kyc: recién registrado, KYC sin revisar. pending_approval: KYC
  // enviado, esperando aprobación manual del admin. approved: puede comprar.
  // rejected / suspended: acceso bloqueado.
  status           String    @default("pending_kyc")
  // Tope de compra por operación/período para este cliente — protege contra
  // que alguien cierre un precio con el proveedor y no pague. Null = sin
  // límite propio (usa el default general, si existe).
  purchaseLimitClp Decimal?  @db.Decimal(18, 2)
  // Margen fijo para ESTE cliente puntual — si está definido, se usa siempre
  // en vez de los tramos generales por monto (UsdtMarginTier). Null = sin
  // override, usa los tramos configurados.
  fixedMarginPct   Decimal?  @db.Decimal(6, 3)
  // 2FA (TOTP) propio del cliente — requerido para retirar. Cifrado
  // reversible porque hace falta el valor real para verificar cada código
  // (no es un hash). totpEnabled queda en false hasta que el cliente
  // confirme un código real durante la configuración.
  totpSecretEnc    String?
  totpEnabled      Boolean   @default(false)
  // Dirección y red donde el cliente quiere recibir sus retiros de USDT —
  // configurable por el propio cliente en su perfil, se usa como default en
  // la pantalla de Retirar.
  walletAddress    String?
  withdrawalNetwork String?  // "TRC20" | "ERC20" | "BEP20"
  // Datos del formulario de KYC tal como los captura el formulario propio del
  // usuario — guardado como JSON en vez de columnas fijas porque el formulario
  // real todavía no fue confirmado (evita inventar nombres de campo).
  kycData          Json?
  approvedAt       DateTime?
  approvedByUserId Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts         UsdtClientContact[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([status])
}

// Libreta de direcciones propia del cliente — contactos externos guardados
// para no tener que escribir la dirección cada vez que retira/envía a la
// misma persona. Vive en nuestra base, no tiene relación con los "contacts"
// de la API de Skipo (esos son de la cuenta del admin, no del cliente).
model UsdtClientContact {
  id        Int      @id @default(autoincrement())
  clientId  Int
  alias     String
  currency  String   @default("USDT")
  network   String   // "TRC20" | "ERC20" | "BEP20"
  address   String
